{
  "name": "rokastro",
  "type": "module",
  "version": "2.1.0",
  "scripts": {
    "dev": "pnpm clean && astro dev",
    "clean": "rm -rf .astro node_modules/.astro node_modules/.vite",
    "build": "astro build && pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "docs": "astro docs",
    "check": "astro check --watch & astro dev --host",
    "lint": "prettier --write  \"**/*.{js,jsx,ts,tsx,md,mdx,astro}\" && eslint --fix \"src/**/*.{js,ts,jsx,tsx,astro}\"",
    "deploy:preview": "npx netlify deploy --no-build --dir $PWD/dist --site f6f6655a-c399-4564-bff5-158e0d698aae --message \"v$npm_package_version\"",
    "deploy:prod": "npx netlify deploy --no-build --prod --dir $PWD/dist --site f6f6655a-c399-4564-bff5-158e0d698aae --message \"v$npm_package_version\""
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/partytown": "^2.1.7",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@types/node": "^26.0.0",
    "astro": "^7.0.2",
    "astro-robots-txt": "^1.0.0",
    "prettier": "^3.8.4",
    "prettier-config-standard": "^7.0.0",
    "prettier-plugin-astro": "^0.14.1",
    "sharp": "^0.35.2",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@astrojs/ts-plugin": "^1.10.9",
    "pagefind": "^1.5.2"
  },
  "packageManager": "pnpm@11.1.0"
}
