---
import { Image } from 'astro:assets'

export interface Props {
  p: any
  alt: string
  quality: string | 'low' //low, mid, high, max
  cssClass: string
  isThumb?: boolean
  transitionName?: string | undefined
}

const { p, alt, quality, cssClass, isThumb, transitionName } = Astro.props
---

<Image
  class={cssClass}
  src={p}
  width={1920}
  alt={alt}
  quality={quality}
  format='avif'
  loading={isThumb ? 'eager' : 'lazy'}
  fetchpriority={isThumb ? 'high' : 'auto'}
  decoding={isThumb ? 'sync' : 'async'}
  data-pagefind-meta={isThumb ? 'image[src]' : undefined}
  transition:name={transitionName}
/>

<style>
  .slide {
    display: block;
    margin-block: 0;
    margin-block-end: var(--spaceTB);
    border-radius: var(--radius);
    width: -webkit-fill-available;
    height: auto;
  }
</style>
